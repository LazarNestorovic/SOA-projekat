{
  "info": {
    "name": "SOA Projekat",
    "_postman_id": "soa-projekat-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "stakeholder_url", "value": "http://localhost:8082" },
    { "key": "blog_url", "value": "http://localhost:8083" },
    { "key": "token", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "blog_id", "value": "" },
    { "key": "comment_id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Registracija - Turista",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{stakeholder_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"turista1\",\n  \"email\": \"turista1@test.com\",\n  \"password\": \"lozinka123\",\n  \"role\": \"turista\"\n}"
            }
          }
        },
        {
          "name": "Registracija - Vodic",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{stakeholder_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"vodic1\",\n  \"email\": \"vodic1@test.com\",\n  \"password\": \"lozinka123\",\n  \"role\": \"vodic\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('Token sačuvan');",
                  "}",
                  "if (res.user && res.user.id) {",
                  "  pm.collectionVariables.set('user_id', res.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{stakeholder_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"turista1\",\n  \"password\": \"lozinka123\"\n}"
            }
          }
        },
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('Admin token sačuvan');",
                  "}",
                  "if (res.user && res.user.id) {",
                  "  pm.collectionVariables.set('user_id', res.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{stakeholder_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Korisnici (Admin)",
      "item": [
        {
          "name": "Moj profil (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{stakeholder_url}}/api/me"
          }
        },
        {
          "name": "Svi korisnici",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{stakeholder_url}}/api/users"
          }
        },
        {
          "name": "Jedan korisnik",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{stakeholder_url}}/api/users/{{user_id}}"
          }
        },
        {
          "name": "Blokiraj korisnika",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{stakeholder_url}}/api/users/{{user_id}}/block"
          }
        }
      ]
    },
    {
      "name": "3. Profil",
      "item": [
        {
          "name": "Pregled profila",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{stakeholder_url}}/api/profile/{{user_id}}"
          }
        },
        {
          "name": "Izmjena profila",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{stakeholder_url}}/api/profile/{{user_id}}/update",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Marko\",\n  \"surname\": \"Marković\",\n  \"biography\": \"Volim putovanja i prirodu.\",\n  \"moto\": \"Carpe diem\",\n  \"image_url\": \"https://example.com/slika.jpg\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "4. Blog (funkcionalnost 6)",
      "item": [
        {
          "name": "Kreiraj blog",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('blog_id', res.id);",
                  "  console.log('Blog ID sačuvan: ' + res.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{blog_url}}/api/blogs",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Moje putovanje u Pariz\",\n  \"description\": \"## Uvod\\n\\nPariz je **predivan** grad!\\n\\n### Što sam posjetio\\n\\n- Eiffelov toranj\\n- Louvre\\n- Notre Dame\\n\\n> Nezaboravno iskustvo.\",\n  \"images\": [\"https://example.com/pariz1.jpg\", \"https://example.com/pariz2.jpg\"]\n}"
            }
          }
        },
        {
          "name": "Kreiraj blog - bez slika",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{blog_url}}/api/blogs",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Savjeti za putovanje\",\n  \"description\": \"# Top 5 savjeta\\n\\n1. Uvijek nosi pasoš\\n2. Rezerviši smještaj unaprijed\\n3. Nauči par fraza na lokalnom jeziku\"\n}"
            }
          }
        },
        {
          "name": "Svi blogovi",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{blog_url}}/api/blogs"
          }
        },
        {
          "name": "Jedan blog",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{blog_url}}/api/blogs/{{blog_id}}"
          }
        }
      ]
    },
    {
      "name": "5. Komentari (funkcionalnost 7)",
      "item": [
        {
          "name": "Dodaj komentar",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('comment_id', res.id);",
                  "  console.log('Komentar ID sačuvan: ' + res.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{blog_url}}/api/blogs/{{blog_id}}/comments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Odličan blog! I ja sam posjetio Pariz prošle godine.\"\n}"
            }
          }
        },
        {
          "name": "Svi komentari bloga",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{blog_url}}/api/blogs/{{blog_id}}/comments"
          }
        },
        {
          "name": "Izmijeni komentar",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{blog_url}}/api/blogs/{{blog_id}}/comments/{{comment_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Izmijenjeni komentar - Pariz je zaista predivan!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "6. Lajkovi (funkcionalnost 8)",
      "item": [
        {
          "name": "Lajkuj blog",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{blog_url}}/api/blogs/{{blog_id}}/like"
          }
        },
        {
          "name": "Lajkuj blog - dupli (treba 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{blog_url}}/api/blogs/{{blog_id}}/like"
          }
        },
        {
          "name": "Ukloni lajk",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{blog_url}}/api/blogs/{{blog_id}}/like"
          }
        }
      ]
    },
    {
      "name": "7. Health check",
      "item": [
        {
          "name": "Auth service health",
          "request": {
            "method": "GET",
            "url": "http://localhost:8081/health"
          }
        },
        {
          "name": "Blog service health",
          "request": {
            "method": "GET",
            "url": "{{blog_url}}/health"
          }
        }
      ]
    }
  ]
}
